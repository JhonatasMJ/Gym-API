{
  "name": "gym-api",
  "version": "1.0.0",
  "description": "GymPass style app.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src --out-dir build",
    "start": "node build/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "text:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JhonatasMJ/Gym-API.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/JhonatasMJ/Gym-API/issues"
  },
  "homepage": "https://github.com/JhonatasMJ/Gym-API#readme",
  "devDependencies": {
    "@rocketseat/eslint-config": "2.2.2",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "eslint": "8.57.1",
    "prettier": "^3.2.5",
    "prisma": "4.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@prisma/client": "4.10.1",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "fastify": "^5.9.0",
    "zod": "4.4.3"
  }
}
