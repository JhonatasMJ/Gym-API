
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//npx prisma -D - instala o prisma
//npx prisma generate - cria a tipagem do prisma
//npm i @prisma/client - cria o client do prisma

//Tabela Usuário
model User {
  @@map("users") 
  id String @id @default(uuid())
  name String
  email String @unique //email unico
}
