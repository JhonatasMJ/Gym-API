
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//npx prisma -D - instala o prisma
//npx prisma generate - cria a tipagem do prisma
//npm i @prisma/client - cria o client do prisma

//Tabela Usuário
model User {
  id String @id @default(uuid())
  name String
  email String @unique //email unico
  password_hash String
  created_at DateTime @default(now())

  @@map("users") //nome da tabela
}

model CheckIn {
  id String @id @default(uuid())
  created_at DateTime @default(now())
  validated_at DateTime?


  @@map("check_ins")
}

model Gym {
    id String @id @default(uuid())
    title String
    description String?
    phone String?
    latitude Decimal
    longitude Decimal

    @@map("gyms") 
}

